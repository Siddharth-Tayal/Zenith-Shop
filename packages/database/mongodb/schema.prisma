generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URL")
}

model Product {
  id        String   @id @map("_id")  
  name        String
  description String
  price       Float
  stock       Int
  category    String
  attributes  Json?    // Flexible fields like { "color": "red", "size": "XL" }
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
